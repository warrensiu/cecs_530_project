    "import matplotlib.pyplot as plt\n",
    "\n",
    "def run_goal_3_scaling_study():\n",
    "    # 1. Define Model Variants (Requirement: At least two variants)\n",
    "    variants = {\n",
    "        \"Small (4 Layers)\": {\"n_layer\": 4, \"n_embd\": 512},\n",
    "        \"Medium (8 Layers)\": {\"n_layer\": 8, \"n_embd\": 512}\n",
    "    }\n",
    "    \n",
    "    # 2. Define Sequence Lengths to study\n",
    "    seq_lengths = [32, 128, 256, 512, 1024]\n",
    "    results = defaultdict(list)\n",
    "\n",
    "    print(\"Starting Scaling Study...\")\n",
    "    for name, v_config in variants.items():\n",
    "        print(f\"Testing {name}...\")\n",
    "        \n",
    "        # Update global config for this variant\n",
    "        config.n_layer = v_config['n_layer']\n",
    "        config.n_embd = v_config['n_embd']\n",
    "        \n",
    "        # Re-instantiate model for this variant\n",
    "        temp_model = LlamaModel(config).to(config.device)\n",
    "        \n",
    "        for length in seq_lengths:\n",
    "            test_prompt = torch.randint(0, config.vocab_size, (1, length)).to(config.device)\n",
    "            \n",
    "            # Use the Goal 1 harness to get steady-state latency\n",
    "            metrics = benchmark_goal_1(temp_model, test_prompt, trials=5, warmups=3)\n",
    "            results[name].append(metrics[\"Per-Token Steady-State (ms)\"])\n",
    "\n",
    "    # 3. Deliverable: Scaling Plots\n",
    "    plt.figure(figsize=(10, 6))\n",
    "    for name, latencies in results.items():\n",
    "        plt.plot(seq_lengths, latencies, marker='o', label=name)\n",
    "    \n",
    "    plt.xlabel('Sequence Length (Tokens)')\n",
    "    plt.ylabel('Per-Token Latency (ms)')\n",
    "    plt.title('Latency Scaling vs. Sequence Length & Model Size')\n",
    "    plt.legend()\n",
    "    plt.grid(True)\n",
    "    plt.show()\n",
    "\n",
    "# Execute Goal 3 Study\n",
    "run_goal_3_scaling_study()"
   ]
